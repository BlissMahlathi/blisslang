BuildSection[
    name: "Hero",
    style.tailwind: "bg-slate-900 min-h-screen flex flex-col justify-center items-center"
]:

    h1[
        text: "Welcome to BlissLang",
        style.tailwind: "text-6xl font-bold text-white",
        animate: "fadeInUp",
        animate.delay: "0ms",
        animate.duration: "800ms",
        animate.trigger: "load"
    ]

    p[
        text: "Build websites section by section. Build enterprise systems without fear.",
        style.tailwind: "text-xl text-blue-200 mt-4 max-w-2xl text-center",
        animate: "fadeInUp",
        animate.delay: "200ms"
    ]

    div[
        style.tailwind: "flex gap-4 mt-8",
        animate: "fadeInUp",
        animate.delay: "400ms"
    ]:
        button[
            text: "Get Started",
            style.tailwind: "px-8 py-3 bg-red-500 text-white rounded-lg font-semibold hover:bg-red-600",
            link: "/docs"
        ]

        button[
            text: "View on GitHub",
            style.tailwind: "px-8 py-3 border border-white text-white rounded-lg font-semibold hover:bg-white hover:text-slate-900",
            link: "https://github.com"
        ]
